{
  "name": "htmlbin",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first HTML hosting. Drop HTML, get a URL. htmlbin.dev",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:apply:local": "wrangler d1 execute htmlbin-db --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute htmlbin-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute htmlbin-db --local --file=./migrations/0001-github-oauth.sql",
    "db:migrate:remote": "wrangler d1 execute htmlbin-db --remote --file=./migrations/0001-github-oauth.sql",
    "setup": "node scripts/setup.mjs",
    "stats": "node scripts/stats.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "BASE_URL=http://localhost:8787 ./scripts/agent-e2e.sh"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "hono": "^4.12.18",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "5.7.2",
    "wrangler": "^4.86.0"
  }
}
