# Copy to .dev.vars (gitignored) for local development.
# These override [vars] in wrangler.toml when running `wrangler dev`.

# Local dev overrides — production uses the values in wrangler.toml.
PUBLIC_URL="http://localhost:8787"

# Random 32+ char string. Generate with:  openssl rand -hex 32
TOKEN_PEPPER="REPLACE_ME_WITH_A_LONG_RANDOM_STRING"

# GitHub OAuth. The sentinel "dev-mock" short-circuits the round-trip
# to github.com — /auth/github/start jumps straight to
# /auth/github/callback with a synthesized github user id derived from
# the `?mock_login=…` query param. The e2e script uses this. Production
# sets these to real values from github.com/settings/applications/new.
GITHUB_CLIENT_ID="dev-mock"
GITHUB_CLIENT_SECRET="dev-mock"

# Sentry observability. Optional in dev. When unset, both the Worker
# wrapper and the browser /sentry.js route no-op. DSN is public — Sentry
# expects it in client code. Set in production via:
#   wrangler secret put SENTRY_DSN
# SENTRY_DSN="https://<publicKey>@oXXXXX.ingest.sentry.io/<project>"
